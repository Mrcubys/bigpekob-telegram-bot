{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/telegram",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/promo",
      "schedule": "0 0 * * *"
    }
  ]
}
